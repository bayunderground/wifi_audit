```gitignore
###############################################################################
# Python
###############################################################################

__pycache__/
*.py[cod]
*$py.class

.venv/
venv/
env/
ENV/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

.mimocode/

###############################################################################
# Build artifacts
###############################################################################

build/
dist/
*.egg-info/

###############################################################################
# IDEs
###############################################################################

.vscode/
.idea/

###############################################################################
# Operating systems
###############################################################################

.DS_Store
Thumbs.db

###############################################################################
# Project runtime data
###############################################################################

logs/*
!logs/.gitkeep

captures/*
!captures/.gitkeep

hashes/*
!hashes/.gitkeep

reports/*
!reports/.gitkeep

###############################################################################
# Persistent application state
###############################################################################

state/*
!state/.gitkeep

###############################################################################
# Temporary files
###############################################################################

*.tmp
*.temp
*.swp
*.swo
*~

###############################################################################
# Wi-Fi capture files
###############################################################################

*.pcap
*.pcapng
*.22000
*.16800
*.hc22000

###############################################################################
# Hashcat
###############################################################################

hashcat.potfile
*.restore
*.log

###############################################################################
# Local configuration overrides
###############################################################################

config/config.local.yaml

###############################################################################
# Test output
###############################################################################

test-output/
```
